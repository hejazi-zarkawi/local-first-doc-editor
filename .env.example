# PostgreSQL connection string. On Vercel, use the pooled connection string
# from your Postgres provider (Neon/Supabase/Vercel Postgres all work well
# with serverless functions).
DATABASE_URL="postgresql://user:password@localhost:5432/doceditor"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me"
NEXTAUTH_URL="http://localhost:3000"

# Optional: AI add-on features (summarize / continue writing).
# Get a free key at https://console.groq.com
GROQ_API_KEY=""
